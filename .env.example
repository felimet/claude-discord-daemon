# claude-discord-daemon — environment variables
#
# The bridge reads DISCORD_BOT_TOKEN from the process environment OR from
# ~/.claude/channels/discord/.env (override that dir with DISCORD_STATE_DIR).
# Copy this file to that .env and fill in your token. Every other var below is
# an OPTIONAL process-env override — leave it commented to take the default.
#
# ── Tip: natural-language "new conversation" reset ──────────────────────────
# Send a message that IS one of these (whole message, case-insensitive) to drop
# the stored session so your next message starts fresh:
#   新對話   開新對話   重新開始   重開   清除對話   忘記
#   /new   /reset   reset   new chat
# The match is strict/whole-message, so a passing mention like
# "來開新對話討論 X" does NOT reset — only a message that is entirely a reset
# phrase does.

# ── required ────────────────────────────────────────────────────────────────
# Your Discord bot token (Discord Developer Portal > your app > Bot > Token).
# A real env var wins over this file. Never commit a real token.
DISCORD_BOT_TOKEN=

# ── optional overrides (defaults shown) ─────────────────────────────────────

# Directory holding .env, access.json, and the inbox/ for downloaded
# attachments. Default: ~/.claude/channels/discord
# DISCORD_STATE_DIR=

# Working dir for sessions.json, outbox/, and bot.log.
# Default: the engine directory (where bot.ts lives).
# BOT_WS_DIR=

# Path to the claude executable the bridge spawns.
# Default: ~/.local/bin/claude
# CLAUDE_BIN=

# Permission mode for spawned runs.
#   auto    = auto-classifier gates each tool call (read-only passes,
#             destructive/self-modifying routes to a Discord Allow/Deny button).
#   default = re-harden: every approval-requiring tool goes through the button
#             flow.
# Never set this to bypassPermissions (Discord input is untrusted).
# Default: auto
# BOT_PERMISSION_MODE=auto

# Claude model for spawned runs; unset = your account default.
# Pin a cheaper model to cut cost, e.g. claude-sonnet-5 or haiku.
# BOT_MODEL=

# Per-run wall-clock cap in ms; 0 = uncapped (long jobs supported).
# Default: 0
# BOT_TIMEOUT_MS=0

# Kill a run after this many ms of stream silence (wedged-process watchdog).
# There is no total time limit — only silence triggers the kill.
# Default: 1800000 (30 min)
# BOT_IDLE_TIMEOUT_MS=1800000

# Loopback port for the permission-approval endpoint (perm-mcp.ts callback).
# Default: 49223
# BOT_PERM_PORT=49223

# An unanswered permission card auto-denies after this many ms.
# Default: 600000 (10 min)
# BOT_PERM_TIMEOUT_MS=600000

# Single-instance loopback lock port (a second launch exits instead of opening
# a second gateway connection on the same token).
# Default: 49222
# BOT_LOCK_PORT=49222
